{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@source/*": ["src/*"],
            "@components/*": ["src/components/*"]
        }
    },
    "include": [
        "docs/**/*.ts",
        "docs/**/*.tsx",
        "docs/**/*.vue",
        "docs/.vuepress/**/*.ts",
        "docs/.vuepress/**/*.vue",
        ".vuepress/**/*.ts",
        ".vuepress/**/*.vue",
        "*.ts"
    ],
    "exclude": ["node_modules"]
}
